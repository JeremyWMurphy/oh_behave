read_in_data = 1;
for i = unique(exp_day)
    rns = {runs{exp_day==i}};
    run_day = rns{1}(5:14);
    run_days{i} = run_day;
    fprintf(['\nDoing ' run_day ', Using files:\n'])  
    for j = 1:numel(rns)
        fprintf([rns{j} ', '])
    end
    if read_in_data
        data = read_teensy_data(pth,rns);
        [S] = get_teensy_behavior(data,fs);
        save([pth 'behavior_' run_day '.mat'],'S')
    end
end

%%

compile_days = [1:24];
get_teensy_behavior_compile(pth,compile_days,run_days,id)
    





